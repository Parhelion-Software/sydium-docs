{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Sydium API",
  "theme": "mint",
  "logo": { "light": "/logo-light.png", "dark": "/logo-dark.png" },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#65A30D",
    "light": "#A3E635",
    "dark": "#4D7C0F"
  },
  "fonts": {
    "heading": { "family": "Space Grotesk" },
    "body": { "family": "Inter" }
  },
  "navbar": {
    "primary": { "type": "button", "label": "Go to Sydium", "href": "https://sydium.com" }
  },
  "footer": {
    "socials": { "x": "https://x.com/DanutPralea", "github": "https://github.com/Parhelion-Software" }
  },
  "seo": {
    "metatags": {
      "og:image": "https://docs.sydium.com/og-image.png",
      "twitter:image": "https://docs.sydium.com/og-image.png",
      "twitter:card": "summary_large_image"
    }
  },
  "navigation": {
    "tabs": [
      { "tab": "Documentation", "groups": [{ "group": "Getting Started", "pages": ["quickstart", "authentication", "errors"] }] },
      { "tab": "MCP", "groups": [
        { "group": "Getting Started", "pages": ["mcp/introduction", "mcp/connect"] },
        { "group": "Reference", "pages": ["mcp/tools", "mcp/examples"] }
      ] },
      { "tab": "CLI", "groups": [{ "group": "Getting Started", "pages": ["cli/introduction", "cli/commands"] }] },
      { "tab": "API Reference", "openapi": "api-reference/openapi.yaml" }
    ]
  }
}
